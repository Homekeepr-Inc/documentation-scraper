{
    # This is a global option block.
    # By default, Caddy will use Let's Encrypt for public domains
    # and its own internal CA for local/private domains (like localhost).
}

{$DOMAIN_NAME} {
    {$TLS_DIRECTIVE}

    log {
        output file /var/log/caddy/access.log {
            roll_size 20mb
            roll_keep 5
            roll_keep_for 168h
        }
        format json
    }

    # Health check endpoints - only accessible from Docker network
    @internal {
        client_ip 172.18.0.0/16  # Docker bridge network range
        path /health
    }
    route @internal {
        reverse_proxy app:8000
    }

    # Main routes with load balancing
    route {
        reverse_proxy documentation-scraper-app-1:8000 documentation-scraper-app-2:8000 documentation-scraper-app-3:8000 documentation-scraper-app-4:8000 {
            lb_policy least_conn
            health_uri /health
            health_interval 2s
            fail_duration 30s
     }
 }
}

outbound.homekeepr.co {
    {$TLS_DIRECTIVE}

    log {
        output file /var/log/caddy/outbound_access.log {
            roll_size 20mb
            roll_keep 5
            roll_keep_for 168h
        }
        format json
    }

    # Security headers
    header_up X-Frame-Options DENY
    header_up X-Content-Type-Options nosniff
    header_up Referrer-Policy strict-origin-when-cross-origin
    header_up Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"

    # Reverse proxy to local service on port 4000
    reverse_proxy app:4000
}
